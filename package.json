{
  "name": "@navikt/klage-file-viewer",
  "version": "1.2.8",
  "type": "module",
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist"],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./styles.css": "./dist/styles.css"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "dev": "vite",
    "dev:build": "vite build --outDir dist --emptyOutDir",
    "dev:preview": "bun dev/server.ts",
    "build": "tsdown && tailwindcss -i src/styles.css -o dist/styles.css --minify",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "knip": "knip",
    "test": "bun test",
    "e2e": "bun run dev:build && playwright test",
    "e2e:headed": "playwright test --headed",
    "e2e:ui": "playwright test --ui"
  },
  "peerDependencies": {
    "@navikt/aksel-icons": "^8.0.0",
    "@navikt/ds-css": "^8.0.0",
    "@navikt/ds-react": "^8.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "@opentelemetry/api": "^1.0.0"
  },
  "peerDependenciesMeta": {
    "@opentelemetry/api": {
      "optional": true
    }
  },
  "dependencies": {
    "tesseract.js": "7.0.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.11.3",
    "@biomejs/biome": "2.5.0",
    "@embedpdf/engines": "2.14.4",
    "@embedpdf/models": "2.14.4",
    "@embedpdf/pdfium": "2.14.4",
    "@navikt/aksel-icons": "8.12.1",
    "@navikt/ds-css": "8.12.1",
    "@navikt/ds-react": "8.12.1",
    "@navikt/ds-tailwind": "8.12.1",
    "@opentelemetry/api": "1.9.1",
    "@playwright/test": "1.60.0",
    "@tailwindcss/cli": "4.3.1",
    "@tailwindcss/postcss": "4.3.1",
    "@types/bun": "1.3.14",
    "@types/jsdom": "28.0.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "jsdom": "29.1.1",
    "knip": "6.16.1",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "tailwindcss": "4.3.1",
    "tsdown": "0.22.2",
    "typescript": "6.0.3",
    "vite": "8.0.16"
  }
}
