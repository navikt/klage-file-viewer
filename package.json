{
  "name": "@navikt/klage-file-viewer",
  "version": "0.0.65",
  "type": "module",
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist"],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./styles.css": "./dist/styles.css",
    "./pdf-worker": "./dist/pdf-worker.min.mjs"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "dev": "vite",
    "dev:build": "vite build --outDir dist --emptyOutDir",
    "dev:preview": "bun dev/server.ts",
    "build": "tsup && tailwindcss -i src/styles.css -o dist/styles.css --minify && cp node_modules/pdfjs-dist/legacy/build/pdf.worker.min.mjs dist/pdf-worker.min.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "knip": "knip",
    "test": "bun test",
    "download-chromium": "scripts/download-chromium.sh",
    "e2e": "bun run dev:build && playwright test",
    "e2e:headed": "playwright test --headed",
    "e2e:ui": "playwright test --ui"
  },
  "peerDependencies": {
    "@navikt/aksel-icons": "^8.0.0",
    "@navikt/ds-css": "^8.0.0",
    "@navikt/ds-react": "^8.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "@opentelemetry/api": "^1.0.0"
  },
  "peerDependenciesMeta": {
    "@opentelemetry/api": {
      "optional": true
    }
  },
  "dependencies": {
    "pdfjs-dist": "5.5.207"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.11.1",
    "@biomejs/biome": "2.4.6",
    "@opentelemetry/api": "1.9.0",
    "@navikt/aksel-icons": "8.7.0",
    "@navikt/ds-css": "8.7.0",
    "@navikt/ds-react": "8.7.0",
    "@navikt/ds-tailwind": "8.7.0",
    "@playwright/test": "1.58.2",
    "@tailwindcss/cli": "4.2.1",
    "@tailwindcss/postcss": "4.2.1",
    "@types/bun": "1.3.10",
    "@types/jsdom": "28.0.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.1.4",
    "jsdom": "28.1.0",
    "knip": "5.86.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwindcss": "4.2.1",
    "tsup": "8.5.1",
    "typescript": "5.9.3",
    "vite": "7.3.1"
  }
}
